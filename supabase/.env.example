# ─────────────────────────────────────────────────────────────────────────────
# CourtPlay — Supabase edge-function secrets (SERVER-SIDE, truly secret)
#
# These are NOT bundled into the client. Set them on your Supabase project with:
#     supabase secrets set --env-file supabase/.env
# (copy this file to supabase/.env, fill in values, then run the command above)
#
# Note: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by
# the Supabase edge runtime — you do NOT need to set them here.
#
# Google OAuth (client ID + secret) is configured in the Supabase dashboard under
# Authentication → Providers → Google, NOT via these secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Resend API key for transactional email (send-email function). Starts with "re_".
RESEND_API_KEY=

# From address for outgoing email.
FROM_EMAIL=CourtPlay <noreply@courtplay.app>

# OneSignal credentials for push (send-notification function).
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
