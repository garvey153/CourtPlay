# ─────────────────────────────────────────────────────────────────────────────
# CourtPlay — Frontend environment (Vite)
#
# Copy this file to `.env.local` and fill in the values:
#     cp .env.example .env.local
#
# ⚠️  Everything here is prefixed VITE_ and is BUNDLED INTO THE CLIENT BUNDLE.
#     These values are PUBLIC — never put a real secret (service-role key,
#     API secret, OAuth client secret) in this file. Server secrets go to
#     Supabase edge functions instead (see supabase/.env.example).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL — https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (safe to expose; protected by Row Level Security).
# Find it in: Supabase dashboard → Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# Client-side field obfuscation key (AES-GCM). NOT a real secret — it ships in
# the browser bundle. Use any 32-character string; it is padded/truncated to 32.
VITE_CRYPTO_KEY=

# OneSignal app ID for web push (public identifier).
# Find it in: OneSignal dashboard → Settings → Keys & IDs → OneSignal App ID
VITE_ONESIGNAL_APP_ID=
